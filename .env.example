PORT=3000

# Webhook auth (optional but recommended in production)
WEBHOOK_SECRET=

# Postgres persistence
# Render will provide this when you attach a PostgreSQL database.
DATABASE_URL=
# Set PGSSL=disable for local non-SSL postgres. Keep default on Render.
PGSSL=require

# Translation toggle
ENABLE_TRANSLATION=false
TRANSLATION_PROVIDER=azure

# Azure Translator (F0 or paid)
AZURE_TRANSLATOR_KEY=your_key_here
AZURE_TRANSLATOR_REGION=your_region_here
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_FROM=sk
AZURE_TRANSLATOR_TO=en
